PORT=4002
NODE_ENV=development

DATABASE_URL=mysql://root:your-root-password@host.docker.internal:3306/trackzen

JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5605

MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_DATABASE=trackzen

# OAuth — Google SSO
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4002/api/v1/auth/oauth/google/callback

# OAuth — Microsoft SSO
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:4002/api/v1/auth/oauth/microsoft/callback

# Email delivery
EMAIL_PROVIDER=sendgrid
FROM_EMAIL=noreply@trackzen.app
FROM_NAME=TrackZen

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# AWS SES (used when EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
